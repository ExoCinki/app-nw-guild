generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  displayName     String?
  discordId       String?   @unique
  accounts        Account[]
  sessions        Session[]
  selectedGuild   SelectedGuild?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WhitelistedGuild {
  id            String   @id @default(cuid())
  discordGuildId String  @unique
  name          String?
  addedByUserId String?
  createdAt     DateTime @default(now())
}

model SelectedGuild {
  id              String   @id @default(cuid())
  userId          String   @unique
  discordGuildId  String
  discordGuildName String?
  discordGuildIconUrl String?
  selectedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuildConfiguration {
  id             String   @id @default(cuid())
  discordGuildId String   @unique
  apiKey         String?  @db.Text
  channelId      String?
  zooMemberRoleId String?
  zooMemberRoleName String?
  warsCount      Int      @default(0)
  racesCount     Int      @default(0)
  invasionsCount Int      @default(0)
  vodsCount      Int      @default(0)
  reviewsCount   Int      @default(0)
  bonusCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Roster {
  id             String        @id @default(cuid())
  discordGuildId String        @unique
  selectedEventId String?
  raidHelperEventsCache Json?
  raidHelperParticipantsCache Json?
  raidHelperEventsCachedAt DateTime?
  raidHelperParticipantsCachedAt DateTime?
  groups         RosterGroup[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model RosterGroup {
  id          String       @id @default(cuid())
  rosterId    String
  groupNumber Int
  name        String?
  slots       RosterSlot[]
  roster      Roster       @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, groupNumber])
}

model RosterSlot {
  id         String      @id @default(cuid())
  groupId    String
  position   Int
  playerName String?
  role       String?
  group      RosterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, position])
}