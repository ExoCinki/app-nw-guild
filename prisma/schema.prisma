generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  displayName     String?
  discordId       String?   @unique
  accounts        Account[]
  sessions        Session[]
  selectedGuild   SelectedGuild?
  guildAccesses   GuildUserAccess[]
  bansIssued      BannedDiscordUser[]
  globalAdmin     GlobalAdmin?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WhitelistedGuild {
  id            String   @id @default(cuid())
  discordGuildId String  @unique
  name          String?
  addedByUserId String?
  createdAt     DateTime @default(now())
}

model SelectedGuild {
  id              String   @id @default(cuid())
  userId          String   @unique
  discordGuildId  String
  discordGuildName String?
  discordGuildIconUrl String?
  selectedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuildConfiguration {
  id             String   @id @default(cuid())
  discordGuildId String   @unique
  apiKey         String?  @db.Text
  channelId      String?
  enableSecondRoster Boolean @default(false)
  zooMemberRoleId String?
  zooMemberRoleName String?
  warsCount      Int      @default(0)
  racesCount     Int      @default(0)
  invasionsCount Int      @default(0)
  vodsCount      Int      @default(0)
  reviewsCount   Int      @default(0)
  bonusCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Roster {
  id             String        @id @default(cuid())
  discordGuildId String        @unique
  selectedEventId String?
  raidHelperEventsCache Json?
  raidHelperParticipantsCache Json?
  raidHelperEventsCachedAt DateTime?
  raidHelperParticipantsCachedAt DateTime?
  groups         RosterGroup[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model RosterGroup {
  id          String       @id @default(cuid())
  rosterId    String
  rosterIndex Int          @default(1)
  groupNumber Int
  name        String?
  slots       RosterSlot[]
  roster      Roster       @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, rosterIndex, groupNumber])
  @@index([rosterId, rosterIndex])
}

model RosterSlot {
  id         String      @id @default(cuid())
  groupId    String
  position   Int
  playerName String?
  role       String?
  group      RosterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, position])
}

model RosterParticipantOverride {
  id             String   @id @default(cuid())
  discordGuildId String
  eventId        String
  participantKey String
  nameOverride   String?
  roleOverride   String?
  isMerc         Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@unique([discordGuildId, eventId, participantKey])
  @@index([discordGuildId, eventId])
}

model RosterArchive {
  id             String   @id @default(cuid())
  discordGuildId String
  eventId        String?
  eventTitle     String?
  archivedAt     DateTime @default(now())
  snapshot       Json
  createdAt      DateTime @default(now())

  @@index([discordGuildId, archivedAt(sort: Desc)])
}

model PayoutSession {
  id             String          @id @default(cuid())
  discordGuildId String
  goldPool       Float           @default(0)
  status         String          @default("DRAFT")
  name           String?
  isLocked       Boolean         @default(false)
  lockedByUserId String?
  entries        PayoutEntry[]
  shares         PayoutSessionShare[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([discordGuildId])
}

model PayoutSessionShare {
  id             String        @id @default(cuid())
  sessionId      String        @unique
  discordGuildId String
  shareTokenHash String        @unique
  shareUrl       String?       @db.Text
  createdByUserId String?
  session        PayoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([discordGuildId])
}

model PayoutEntry {
  id             String          @id @default(cuid())
  sessionId      String
  discordGuildId String
  discordUserId  String
  username       String
  displayName    String?
  wars           Int             @default(0)
  races          Int             @default(0)
  reviews        Int             @default(0)
  bonus          Int             @default(0)
  invasions      Int             @default(0)
  vods           Int             @default(0)
  isPaid         Boolean         @default(false)
  session        PayoutSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([sessionId, discordUserId])
  @@index([discordGuildId])
}

model ScoreboardSession {
  id             String            @id @default(cuid())
  discordGuildId String
  name           String?
  status         String            @default("DRAFT")
  entries        ScoreboardEntry[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([discordGuildId, createdAt(sort: Desc)])
}

model ScoreboardEntry {
  id                String            @id @default(cuid())
  sessionId         String
  discordGuildId    String
  playerName        String
  playerNameKey     String
  kills             Int               @default(0)
  deaths            Int               @default(0)
  assists           Int               @default(0)
  damageDealt       Int               @default(0)
  healingDone       Int               @default(0)
  session           ScoreboardSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([sessionId, playerNameKey])
  @@index([discordGuildId, playerNameKey])
  @@index([sessionId])
}

model GuildUserAccess {
  id                     String   @id @default(cuid())
  userId                 String
  discordGuildId         String
  canReadRoster          Boolean  @default(true)
  canWriteRoster         Boolean  @default(true)
  canReadPayout          Boolean  @default(true)
  canWritePayout         Boolean  @default(true)
  canReadScoreboard      Boolean  @default(true)
  canWriteScoreboard     Boolean  @default(true)
  canReadConfiguration   Boolean  @default(true)
  canWriteConfiguration  Boolean  @default(true)
  canReadArchives        Boolean  @default(true)
  canWriteArchives       Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, discordGuildId])
  @@index([discordGuildId])
}

model GlobalAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BannedDiscordUser {
  id            String   @id @default(cuid())
  discordId     String   @unique
  reason        String?
  bannedByUserId String?
  createdAt     DateTime @default(now())

  bannedByUser User? @relation(fields: [bannedByUserId], references: [id], onDelete: SetNull)
}